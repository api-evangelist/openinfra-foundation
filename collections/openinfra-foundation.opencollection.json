        "type": "http"
      },
      "http": {
        "method": "POST",
        "url": "https://example.openstack.local/v3/auth/tokens",
        "body": {
          "type": "json",
          "data": "{}"
        }
      },
      "docs": "Authenticate identity and generate a token"
    },
    {
      "info": {
        "name": "Revoke a token",
        "type": "http"
      },
      "http": {
        "method": "DELETE",
        "url": "https://example.openstack.local/v3/auth/tokens"
      },
      "docs": "Revoke a token"
    },
